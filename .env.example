# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon)
# Get a free Postgres instance at https://neon.tech and paste the connection string.
DATABASE_URL=

# Auth (Clerk) — https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional for local dev. Required in production so the user.created webhook can
# verify signatures. Without it, users are still lazily provisioned on first
# request — see src/lib/auth-helpers.ts.
CLERK_WEBHOOK_SECRET=

# Transcripts (Supadata) — https://supadata.ai
SUPADATA_API_KEY=

# LLM — Google AI Studio (https://aistudio.google.com)
GOOGLE_GENERATIVE_AI_API_KEY=
