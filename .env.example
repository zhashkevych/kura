# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon)
DATABASE_URL=

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional for local dev. Required in production so the webhook can verify signatures.
CLERK_WEBHOOK_SECRET=

# Transcripts (Supadata)
SUPADATA_API_KEY=

# LLMs
GOOGLE_GENERATIVE_AI_API_KEY=
# v1.1 — premium toggle
ANTHROPIC_API_KEY=

# Notion (v1.1)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/notion/callback

# Encryption for stored OAuth tokens (v1.1) — generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Rate limiting
FREE_TIER_MONTHLY_LIMIT=10

# Stripe (v0.2 billing)
# Use sk_test_... keys in dev, sk_live_... in prod. Price IDs look identical across modes —
# double-check you're using test-mode prices locally.
STRIPE_SECRET_KEY=
# For local dev this comes from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`.
# It is distinct from the production webhook secret.
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=price_
STRIPE_PRICE_YEARLY=price_
